  Node1 [id="Node000001",label="IGameState",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip="Interface for Game States."];
  Node1 -> Node2 [id="edge1_Node000001_Node000002",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node2 [id="Node000002",label="CombatState",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$classCombatState.html",tooltip="Combat state managing turn-based combat."];
  Node1 -> Node3 [id="edge2_Node000001_Node000003",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node3 [id="Node000003",label="ExplorationState",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$classExplorationState.html",tooltip="Exploration state where the player moves around the map and manages inventory."];
